{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gdd_decisions_list",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["locked", "tentative"] }
      }
    },
    "output": {
      "type": "object",
      "required": ["decisions"],
      "properties": {
        "decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "text", "status"],
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "status": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
