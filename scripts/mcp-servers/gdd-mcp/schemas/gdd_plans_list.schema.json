{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gdd_plans_list",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "phase": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "required": ["phase", "plans"],
      "properties": {
        "phase": { "type": ["string", "null"] },
        "plans": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "status"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "status": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
